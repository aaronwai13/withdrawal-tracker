{
  "rules": {
    "records_2026": {
      ".read": true,
      ".write": "auth != null && (auth.token.email == 'nentivericfv@gmail.com' || auth.token.email == '1252719751@qq.com')",
      "$record": {
        ".validate": "newData.hasChildren(['date', 'amount', 'ts'])",
        "date": {
          ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)"
        },
        "amount": {
          ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= 100000"
        },
        "ts": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
